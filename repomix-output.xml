<file path="src/validation/metrics.ts">
/**
 * metrics.ts
 *
 * Métricas de validación orbital.
 * Cada función delega a los módulos de física correspondientes.
 */

import { energyDrift } from "@/physics/energy";
import type { BodyState } from "@/types";

export function calculateOrbitalError(
  initialX: number,
  initialY: number,
  finalX: number,
  finalY: number,
): number {
  const dx = finalX - initialX;
  const dy = finalY - initialY;
  return Math.sqrt(dx * dx + dy * dy);
}

export function calculateEnergyDrift(current: number, initial: number): number {
  return energyDrift(current, initial);
}

export function calculateAngularMomentum(bodies: BodyState[]): number {
  // L = Σ m_i * (x_i * vy_i - y_i * vx_i)
  return bodies.reduce((sum, b) => sum + b.mass * (b.x * b.vy - b.y * b.vx), 0);
}
