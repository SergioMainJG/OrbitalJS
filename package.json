{
  "name": "orbital-js",
  "version": "0.0.0",
  "description": "Simulador de órbitas planetarias con integración numérica RK4, SolidJS y Canvas 2D",
  "type": "module",
  "scripts": {
    "postinstall": "simple-git-hooks",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type:check": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "fmt": "oxfmt 'src/**/*.ts' && prettier --write \"src/**/*.{html,tsx,css}\"",
    "fmt:check": "oxfmt --check 'src/**/*.ts' && prettier --check \"src/**/*.{html,tsx,css}\"",
    "check": "bun run lint && bun run fmt:check && bun run type:check && bun run test:ci"
  },
  "license": "MIT",
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^25.0.1",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "simple-git-hooks": "^2.13.1",
    "solid-devtools": "^0.34.3",
    "typescript": "^5.7.2",
    "vite": "npm:rolldown-vite@latest",
    "vite-plugin-solid": "2.11.9",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "chart.js": "^4.5.1",
    "daisyui": "^5.5.19",
    "solid-js": "^1.9.5",
    "tailwindcss": "^4.2.4"
  },
  "packageManager": "bun@1.3.13",
  "simple-git-hooks": {
    "pre-commit": "bun run fmt:check && bun run lint",
    "pre-push": "bun run check"
  }
}
